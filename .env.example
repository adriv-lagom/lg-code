# ── Worker LLM: local vLLM or any OpenAI-compatible endpoint ────────────────
# For vLLM locally: leave as-is
# For DeepSeek as worker too: set BASE_URL to https://api.deepseek.com/v1
# For no local GPU: set LOCAL_MODEL=deepseek-chat and use SUPERVISOR creds
LOCAL_BASE_URL=http://127.0.0.1:8002/v1
LOCAL_MODEL=local-active-agent
LOCAL_API_KEY=dummy

# ── Supervisor: DeepSeek (orchestrates, diagnoses) ─────────────────────────
# Get your API key at https://platform.deepseek.com/api_keys
SUPERVISOR_BASE_URL=https://api.deepseek.com/v1
SUPERVISOR_MODEL=deepseek-v4-pro
SUPERVISOR_API_KEY=sk-YOUR_DEEPSEEK_API_KEY_HERE

# ── LangSmith (optional) ───────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGGRAPH_CLI_NO_ANALYTICS=1
# LANGSMITH_API_KEY=...

# ── Julia multi-repo agent ─────────────────────────────────────────────────
# Format: shortname=absolute/path,shortname=absolute/path
JULIA_REPOS="bhe=/path/to/BoreholeHeatExchanger,rht=/path/to/ReducedHeatTransfer,tf=/path/to/ThermoFluid,bp=/path/to/BuildingPhysics"
# Dependency graph: upstream:downstream
JULIA_DEPS="rht:bhe,tf:bhe"

# ── Node-RED flow editor agent ─────────────────────────────────────────────
# NODERED_FLOW_PATH=/absolute/path/to/flows.json
# NODERED_FLOWS_DIR=/absolute/path/to/flows_dir/
